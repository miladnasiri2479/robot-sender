# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=robot_sender
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Bot Tokens
SOROUSH_TOKEN=your_soroush_token
TELEGRAM_TOKEN=your_telegram_token
EITAA_TOKEN=your_eitaa_token
RUBIKA_TOKEN=your_rubika_token
BALE_TOKEN=your_bale_token

# Channels Configuration (Mapping)
# You can also use a config.json for more complex mapping
SOROUSH_CHANNEL_ID=your_soroush_channel_id
TELEGRAM_CHANNEL_ID=@your_telegram_channel
EITAA_CHANNEL_ID=your_eitaa_channel
RUBIKA_CHANNEL_ID=your_rubika_channel
BALE_CHANNEL_ID=your_bale_channel
